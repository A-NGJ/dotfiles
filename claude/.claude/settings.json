{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/bin/statusline.sh"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check_code_quality_python.sh"
          }
        ]
      }
    ]
  }
}
